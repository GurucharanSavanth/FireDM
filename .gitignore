# Ignore all files and directories by default.
*

# Generated outputs and local state. These are covered by the catch-all above,
# but the explicit patterns keep intent visible when this allowlist changes.
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/
.nox/
.venv/
venv/
env/
build/
dist/
*.egg-info/
*.spec.tmp
release-output/
installer-output/
artifacts/tmp/
artifacts/**/tmp/
artifacts/**/logs/
artifacts/**/screenshots/
artifacts/**/manual_qa_local/
artifacts/full_codebase_repair/pyinstaller-build/
artifacts/full_codebase_repair/pyinstaller-dist/
*.exe
*.msi
*.msix
*.msixbundle
*.zip
*.7z
*.tar
*.gz
*.log

